<script>
  (function(){
    var nav = document.querySelector('nav');
    if(!nav) return;
    var toggle = nav.querySelector('.nav-toggle');
    if(toggle){
      toggle.addEventListener('click', function(e){
        e.stopPropagation();
        var open = nav.classList.toggle('nav-open');
        toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
      });
    }
    nav.querySelectorAll('.nav-has-dropdown > span').forEach(function(span){
      span.addEventListener('click', function(e){
        if(window.matchMedia('(max-width:880px)').matches){
          e.preventDefault();
          var li = span.parentElement;
          var wasOpen = li.classList.contains('dropdown-open');
          nav.querySelectorAll('.nav-has-dropdown.dropdown-open').forEach(function(other){
            if(other !== li) other.classList.remove('dropdown-open');
          });
          li.classList.toggle('dropdown-open', !wasOpen);
        }
      });
    });
  })();
</script>
