<script is:inline>
(function(){
  document.addEventListener('click', function(e){
    var link = e.target.closest && e.target.closest('a');
    if(!link || !link.href) return;
    if(link.href.indexOf('opus1.io') === -1) return;
    if(link.href.indexOf('/login') !== -1) return;
    if(link.href.indexOf('/w/recitals') !== -1) return;

    var location = window.location.pathname || '/';
    var decoratedHref = link.href;

    if(window.CSMAttribution && typeof window.CSMAttribution.decorateUrl === 'function'){
      decoratedHref = window.CSMAttribution.decorateUrl(link.href);
      link.href = decoratedHref;
    }

    if(window.dataLayer){
      var attribution = window.CSMAttribution && typeof window.CSMAttribution.getLatest === 'function'
        ? window.CSMAttribution.getLatest()
        : {};
      window.dataLayer.push({
        event: 'book_intro_click',
        link_url: decoratedHref,
        page_path: location,
        link_text: (link.textContent || '').trim().slice(0, 80),
        gclid: attribution.gclid || '',
        gbraid: attribution.gbraid || '',
        wbraid: attribution.wbraid || '',
        utm_source: attribution.utm_source || '',
        utm_medium: attribution.utm_medium || '',
        utm_campaign: attribution.utm_campaign || '',
        first_landing_path: attribution.first_landing_path || '',
        latest_landing_path: attribution.latest_landing_path || ''
      });
    }
    if(typeof fbq === 'function'){
      fbq('track', 'Lead', {
        content_name: 'Book Intro Lesson',
        content_category: location
      });
    }
  }, true);
})();
</script>
