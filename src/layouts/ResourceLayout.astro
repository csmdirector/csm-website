---
import Base from './Base.astro';

interface Props {
  title: string;
  seoTitle?: string;
  description: string;
  canonicalPath?: string;
  categories?: string[];
  tags?: string[];
  instruments?: string[];
  publishDate?: Date;
  updatedDate?: Date;
  relatedResources?: Array<{
    title: string;
    description: string;
    href: string;
    categories: string[];
  }>;
  ctaLabel?: string;
  ctaHref?: string;
}

const {
  title,
  seoTitle,
  description,
  canonicalPath,
  categories = [],
  tags = [],
  instruments = [],
  publishDate,
  updatedDate,
  relatedResources = [],
  ctaLabel = 'Book Intro',
  ctaHref = 'https://cincinnatischoolofmusic.opus1.io/w/book-your-intro-lesson'
} = Astro.props;

const labels = [...categories, ...tags, ...instruments];
const dateLabel = updatedDate || publishDate;
const slugifyLocal = (value: string) => value.toLowerCase().trim().replace(/&/g, 'and').replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
const fallbackRelated = categories.length > 0 ? [{
  title: `Browse ${categories[0]} Resources`,
  description: 'See parent guidance grouped around this topic as the Resource Hub grows.',
  href: `/parent-resources/category/${slugifyLocal(categories[0])}/`,
  categories: [categories[0]]
}] : [];
const relatedItems = relatedResources.length > 0 ? relatedResources : fallbackRelated;
---
<Base title={seoTitle || `${title} | Cincinnati School of Music`} description={description} canonicalPath={canonicalPath}>
  <article class="page-shell resource-article">
    <div class="page-inner narrow">
      <span class="section-label">Parent Resource</span>
      <h1>{title}</h1>
      <p class="resource-description">{description}</p>
      {dateLabel && <p class="resource-date">Updated {dateLabel.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric', timeZone: 'UTC' })}</p>}
      {labels.length > 0 && (
        <div class="resource-tags" aria-label="Resource topics">
          {labels.map((label) => <span>{label}</span>)}
        </div>
      )}
      <div class="resource-body">
        <slot />
      </div>
      {relatedItems.length > 0 && (
        <section class="related-resources" aria-labelledby="related-resources-title">
          <span class="section-label">Keep Reading</span>
          <h2 id="related-resources-title">Related Resources</h2>
          <div class="related-grid">
            {relatedItems.map((resource) => (
              <a class="related-card" href={resource.href}>
                <span>{resource.categories[0] || 'Parent Resource'}</span>
                <strong>{resource.title}</strong>
                <p>{resource.description}</p>
              </a>
            ))}
          </div>
        </section>
      )}
      <aside class="resource-cta" aria-labelledby="resource-cta-title">
        <div>
          <span class="section-label">Next Step</span>
          <h2 id="resource-cta-title">Find the right lesson fit.</h2>
          <p>CSM can help match your student with the right teacher, instrument, and location.</p>
        </div>
        <div class="cta-actions">
          <a class="btn-a" href={ctaHref}>{ctaLabel}</a>
          <a class="btn-c" href="/smart-intro-intake/">Lesson Fit Finder</a>
        </div>
      </aside>
    </div>
  </article>
  <style>
    .resource-description{font-size:1rem;margin-bottom:28px}
    .resource-date{font-size:.72rem;letter-spacing:.12em;text-transform:uppercase;margin-bottom:18px;color:var(--light)}
    .resource-tags{display:flex;flex-wrap:wrap;gap:8px;margin:0 0 44px}
    .resource-tags span{border:1px solid var(--offwb);color:var(--mid);font-size:.62rem;font-weight:500;letter-spacing:.13em;text-transform:uppercase;padding:7px 10px}
    .resource-body :global(h2){margin-top:44px}
    .resource-body :global(p){margin:0 0 20px}
    .resource-body :global(ul),.resource-body :global(ol){color:var(--mid);padding-left:24px;margin:0 0 24px}
    .resource-body :global(li){margin-bottom:8px}
    .related-resources{border-top:1px solid var(--offwb);margin-top:56px;padding-top:40px}
    .related-grid{display:grid;grid-template-columns:1fr;gap:1px;background:var(--offwb);border:1px solid var(--offwb);margin-top:24px}
    .related-card{display:block;background:var(--white);padding:24px;text-decoration:none;transition:background .18s}
    .related-card:hover{background:var(--offwhite)}
    .related-card span{display:block;font-size:.58rem;font-weight:600;letter-spacing:.16em;text-transform:uppercase;color:var(--slate);margin-bottom:8px}
    .related-card strong{display:block;font-size:1rem;font-weight:500;color:var(--charcoal);margin-bottom:8px}
    .related-card p{font-size:.84rem;line-height:1.7}
    .resource-cta{border-top:1px solid var(--offwb);margin-top:56px;padding-top:40px;display:grid;grid-template-columns:1fr auto;gap:32px;align-items:center}
    .resource-cta p{margin-bottom:24px}
    .cta-actions{display:flex;gap:12px;flex-wrap:wrap;justify-content:flex-end}
    @media(max-width:880px){
      .resource-cta{grid-template-columns:1fr}
      .cta-actions{justify-content:flex-start}
    }
  </style>
</Base>
