---
import Base from './Base.astro';

interface Props {
  title: string;
  description: string;
  eyebrow: string;
  canonicalPath?: string;
}

const { title, description, eyebrow, canonicalPath } = Astro.props;
---
<Base title={`${title} | Cincinnati School of Music`} description={description} canonicalPath={canonicalPath}>
  <section class="page-shell">
    <div class="page-inner">
      <span class="section-label">{eyebrow}</span>
      <h1>{title}</h1>
      <p class="program-description">{description}</p>
      <slot />
    </div>
  </section>
  <style>
    .program-description{max-width:680px;margin-bottom:48px}
  </style>
</Base>
