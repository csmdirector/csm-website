---
import Base from '../../layouts/Base.astro';
---
<Base
  title="Intro Lesson Next Step | Cincinnati School of Music"
  description="Continue from Lesson Fit to book an Intro Lesson with Cincinnati School of Music."
  canonicalPath="/lesson-fit/thank-you/"
  noindex={true}
>
  <section class="page-shell">
    <div class="page-inner narrow thank-you">
      <span class="section-label">Next Step</span>
      <h1 id="thankYouTitle">Continue to your Intro Lesson booking.</h1>
      <p id="thankYouLead">
        Thanks. Your answers help keep the next step focused.
      </p>
      <p id="thankYouBody">
        The next step is the Cincinnati School of Music booking page for your Intro Lesson.
      </p>
      <div class="thank-you-actions">
        <a class="btn-a" id="thankYouBookingLink" href="https://cincinnatischoolofmusic.opus1.io/w/book-your-intro-lesson">Book an Intro Lesson</a>
        <a class="btn-c help-link" id="thankYouCallLink" href="tel:5135609175">Call CSM</a>
        <a class="btn-c help-link" id="thankYouTextLink" href="sms:5135609175">Text CSM</a>
        <a class="btn-c help-link" id="thankYouEmailLink" href="mailto:info@cincinnatischoolofmusic.com">Email CSM</a>
        <a class="btn-c" href="/parent-resources/">Visit Parent Resources</a>
      </div>
    </div>
  </section>

  <style>
    .thank-you{padding-top:104px}
    .thank-you p{margin-bottom:18px}
    .thank-you-actions{display:flex;flex-wrap:wrap;gap:12px;margin-top:34px}
    .help-link{display:none}
    .thank-you.is-help .help-link{display:inline-block}
    .thank-you.is-help #thankYouBookingLink{display:none}
  </style>

  <script>
    (function(){
      var link = document.getElementById('thankYouBookingLink');
      var keys = ['utm_source','utm_medium','utm_campaign','utm_content','utm_term','gclid','gbraid','wbraid'];
      var params = new URLSearchParams(window.location.search);
      var isHelp = params.get('help') === '1';
      var HELP_SUBMIT_EVENT_SENT_KEY = 'csmLessonFitHelpSubmitEventSent';
      try {
        var stored = JSON.parse(window.localStorage.getItem('csmLessonFitAttribution') || '{}') || {};
        if(link){
          var url = new URL(link.href);
          keys.forEach(function(key){
            if(stored[key]){
              url.searchParams.set(key, stored[key]);
            }
          });
          link.href = url.toString();
        }
        if(isHelp && window.dataLayer && window.sessionStorage.getItem(HELP_SUBMIT_EVENT_SENT_KEY) !== '1'){
          window.dataLayer.push({
            event: 'lesson_fit_help_submit',
            routing_outcome: 'staff-help',
            utm_source: stored.utm_source || params.get('utm_source') || '',
            utm_medium: stored.utm_medium || params.get('utm_medium') || '',
            utm_campaign: stored.utm_campaign || params.get('utm_campaign') || '',
            utm_content: stored.utm_content || params.get('utm_content') || '',
            utm_term: stored.utm_term || params.get('utm_term') || '',
            gclid: stored.gclid || params.get('gclid') || '',
            gbraid: stored.gbraid || params.get('gbraid') || '',
            wbraid: stored.wbraid || params.get('wbraid') || '',
            click_id: stored.gclid || stored.gbraid || stored.wbraid || params.get('gclid') || params.get('gbraid') || params.get('wbraid') || '',
            landing_path: stored.landing_path || params.get('landing_path') || '',
            referrer: stored.referrer || params.get('referrer') || ''
          });
          window.sessionStorage.setItem(HELP_SUBMIT_EVENT_SENT_KEY, '1');
        }
      } catch (error) {}
      if(isHelp){
        var shell = document.querySelector('.thank-you');
        var title = document.getElementById('thankYouTitle');
        var lead = document.getElementById('thankYouLead');
        var body = document.getElementById('thankYouBody');
        if(shell) shell.classList.add('is-help');
        if(title) title.textContent = 'CSM can help with the next step.';
        if(lead) lead.textContent = 'Thanks. Your request was sent.';
        if(body) body.textContent = 'We will use your answers when we reach out.';
      }
    })();
  </script>
</Base>
