---
import Base from '../../layouts/Base.astro';
---
<Base
  title="Lesson Fit Request Sent | Cincinnati School of Music"
  description="Confirmation that Cincinnati School of Music received a Lesson Fit help request."
  canonicalPath="/lesson-fit/thank-you/"
  noindex={true}
>
  <section class="page-shell">
    <div class="page-inner narrow thank-you">
      <span class="section-label">Request Sent</span>
      <h1>CSM can help with the next step.</h1>
      <p>
        Thanks. Your answers were sent to Cincinnati School of Music, and we will use them when we reach out.
      </p>
      <div class="thank-you-actions">
        <a class="btn-c" href="tel:5135609175">Call CSM</a>
        <a class="btn-c" href="sms:5135609175">Text CSM</a>
        <a class="btn-c" href="mailto:info@cincinnatischoolofmusic.com">Email CSM</a>
        <a class="btn-c" href="/lesson-fit/">Back to Lesson Fit</a>
      </div>
    </div>
  </section>

  <style>
    .thank-you{padding-top:104px}
    .thank-you p{margin-bottom:18px;max-width:640px}
    .thank-you-actions{display:flex;flex-wrap:wrap;gap:12px;margin-top:34px}
    @media(max-width:560px){
      .thank-you-actions{display:grid;grid-template-columns:1fr}
      .thank-you-actions .btn-c{text-align:center;padding-left:18px;padding-right:18px}
    }
  </style>

  <script>
    (function(){
      var keys = ['utm_source','utm_medium','utm_campaign','utm_content','utm_term','gclid','gbraid','wbraid'];
      var params = new URLSearchParams(window.location.search);
      var HELP_SUBMIT_EVENT_PUSHED_KEY = 'csmLessonFitHelpSubmitEventPushed';
      var HELP_SUBMIT_PAYLOAD_KEY = 'csmLessonFitHelpSubmitPayload';

      function readJson(storage, key){
        try {
          return JSON.parse(storage.getItem(key) || '{}') || {};
        } catch (error) {
          return {};
        }
      }

      function normalizeAttribution(value){
        var attribution = value || {};
        var flat = {};
        keys.forEach(function(key){
          flat[key] = attribution[key] || '';
        });
        flat.first_landing_path = attribution.first_landing_path || attribution.landing_path || '';
        flat.latest_landing_path = attribution.latest_landing_path || attribution.landing_path || flat.first_landing_path || '';
        flat.landing_path = flat.latest_landing_path;
        flat.referrer = attribution.referrer || '';
        flat.timestamp = attribution.timestamp || attribution.attribution_timestamp || '';
        return flat;
      }

      function getStoredAttribution(){
        if(window.CSMAttribution && typeof window.CSMAttribution.getLatest === 'function'){
          return normalizeAttribution(window.CSMAttribution.getLatest());
        }
        var legacy = readJson(window.localStorage, 'csmLessonFitAttribution');
        var sitewide = readJson(window.localStorage, 'csmAttribution');
        var first = sitewide.first_touch || {};
        var latest = sitewide.latest_touch || first || {};
        var flat = normalizeAttribution(Object.assign({}, legacy, latest));
        flat.first_landing_path = first.first_landing_path || first.latest_landing_path || flat.first_landing_path || '';
        flat.latest_landing_path = latest.latest_landing_path || latest.first_landing_path || flat.latest_landing_path || flat.first_landing_path || '';
        flat.landing_path = flat.latest_landing_path;
        return flat;
      }

      try {
        if(!window.dataLayer || window.sessionStorage.getItem(HELP_SUBMIT_EVENT_PUSHED_KEY) === '1') return;
        var attribution = getStoredAttribution();
        var helpPayload = readJson(window.sessionStorage, HELP_SUBMIT_PAYLOAD_KEY);
        helpPayload.event = 'lesson_fit_help_submit';
        helpPayload.routing_outcome = helpPayload.routing_outcome || 'staff-help';
        helpPayload.utm_source = helpPayload.utm_source || attribution.utm_source || params.get('utm_source') || '';
        helpPayload.utm_medium = helpPayload.utm_medium || attribution.utm_medium || params.get('utm_medium') || '';
        helpPayload.utm_campaign = helpPayload.utm_campaign || attribution.utm_campaign || params.get('utm_campaign') || '';
        helpPayload.utm_content = helpPayload.utm_content || attribution.utm_content || params.get('utm_content') || '';
        helpPayload.utm_term = helpPayload.utm_term || attribution.utm_term || params.get('utm_term') || '';
        helpPayload.gclid = helpPayload.gclid || attribution.gclid || params.get('gclid') || '';
        helpPayload.gbraid = helpPayload.gbraid || attribution.gbraid || params.get('gbraid') || '';
        helpPayload.wbraid = helpPayload.wbraid || attribution.wbraid || params.get('wbraid') || '';
        helpPayload.click_id = helpPayload.click_id || attribution.gclid || attribution.gbraid || attribution.wbraid || params.get('gclid') || params.get('gbraid') || params.get('wbraid') || '';
        helpPayload.landing_path = helpPayload.landing_path || attribution.latest_landing_path || attribution.landing_path || params.get('latest_landing_path') || params.get('landing_path') || '';
        helpPayload.first_landing_path = helpPayload.first_landing_path || attribution.first_landing_path || params.get('first_landing_path') || '';
        helpPayload.latest_landing_path = helpPayload.latest_landing_path || attribution.latest_landing_path || params.get('latest_landing_path') || params.get('landing_path') || '';
        helpPayload.referrer = helpPayload.referrer || attribution.referrer || params.get('referrer') || '';
        helpPayload.attribution_timestamp = helpPayload.attribution_timestamp || attribution.timestamp || params.get('attribution_timestamp') || '';
        window.dataLayer.push(helpPayload);
        window.sessionStorage.setItem(HELP_SUBMIT_EVENT_PUSHED_KEY, '1');
      } catch (error) {}
    })();
  </script>
</Base>
