---
import Base from '../layouts/Base.astro';
---
<Base
  title="Lead Pipeline Webhook Test | Cincinnati School of Music"
  description="Temporary test-only form for lead pipeline webhook validation."
  canonicalPath="/lead-pipeline-webhook-test/"
  noindex={true}
>
  <section class="page-shell">
    <div class="page-inner narrow webhook-test">
      <span class="section-label">Internal Test</span>
      <h1>Lead pipeline webhook test</h1>
      <p>This temporary form is only for validating the Phase 1 Netlify Form webhook path.</p>

      <form
        name="lead-pipeline-webhook-test"
        method="POST"
        action="/lead-pipeline-webhook-test/"
        data-netlify="true"
        netlify-honeypot="bot-field"
      >
        <input type="hidden" name="form-name" value="lead-pipeline-webhook-test" />
        <input type="hidden" name="subject" value="Lead Pipeline Webhook Test" />
        <input type="hidden" name="routing_outcome" value="webhook-test" />
        <input type="hidden" name="recommended_url" value="/lead-pipeline-webhook-test/" />
        <input type="hidden" name="utm_source" value="codex" />
        <input type="hidden" name="utm_medium" value="netlify-form-webhook" />
        <input type="hidden" name="utm_campaign" value="lead-pipeline-phase-1" />
        <input type="hidden" name="landing_path" value="/lead-pipeline-webhook-test/" />
        <p class="hidden-field">
          <label>Do not fill this out if you are human: <input name="bot-field" /></label>
        </p>

        <label>
          Name
          <input name="parent_name" value="Codex Form Webhook Test" required />
        </label>
        <label>
          Email
          <input name="email" type="email" value="codex.form.webhook.test@example.com" required />
        </label>
        <label>
          Phone
          <input name="phone" type="tel" value="513-555-0205" />
        </label>
        <label>
          Instrument
          <input name="instrument_interest" value="Piano" />
        </label>
        <label>
          Student age
          <input name="student_age" value="Adult" />
        </label>
        <label>
          Preferred location
          <input name="preferred_location" value="Olde Montgomery" />
        </label>
        <label>
          Next step
          <input name="next_step_preference" value="I want CSM to help me choose" />
        </label>
        <label>
          Help reason
          <input name="help_reason" value="Netlify Form webhook proof" />
        </label>
        <label>
          Test marker
          <textarea name="student_context" rows="3" required>CODEX_FORM_WEBHOOK_TEST_PENDING</textarea>
        </label>
        <label>
          Lesson request
          <textarea name="lesson_request" rows="3">Piano | Adult | Olde Montgomery | Netlify Form webhook proof</textarea>
        </label>
        <label>
          Follow-up notes
          <textarea name="follow_up_notes" rows="3">CODEX_FORM_WEBHOOK_TEST_PENDING</textarea>
        </label>
        <label>
          Tracking summary
          <textarea name="tracking_summary" rows="4">Source: codex / netlify-form-webhook
Campaign: lead-pipeline-phase-1
Content: CODEX_FORM_WEBHOOK_TEST_PENDING
Landing page: /lead-pipeline-webhook-test/</textarea>
        </label>
        <input name="submitted_at" value="2026-07-05T00:00:00Z" />
        <input name="utm_content" value="CODEX_FORM_WEBHOOK_TEST_PENDING" />

        <button type="submit" class="btn-a">Submit Test</button>
      </form>
    </div>
  </section>
</Base>

<style>
  .webhook-test form {
    display: grid;
    gap: 18px;
    margin-top: 32px;
    max-width: 640px;
  }

  .webhook-test label {
    display: grid;
    gap: 6px;
    color: var(--charcoal);
    font-size: .76rem;
    font-weight: 500;
    letter-spacing: .08em;
    text-transform: uppercase;
  }

  .webhook-test input,
  .webhook-test textarea {
    width: 100%;
    border: 1px solid var(--offwb);
    background: var(--white);
    color: var(--charcoal);
    font: 300 1rem/1.5 var(--f);
    letter-spacing: 0;
    padding: 12px 14px;
  }

  .webhook-test .hidden-field {
    display: none;
  }

  .webhook-test button {
    border: 0;
    justify-self: start;
    cursor: pointer;
  }
</style>
