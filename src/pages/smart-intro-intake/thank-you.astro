---
import Base from '../../layouts/Base.astro';
---
<Base
  title="Smart Intro Intake Received | Cincinnati School of Music"
  description="Confirmation that Cincinnati School of Music received a Smart Intro Intake submission."
  canonicalPath="/smart-intro-intake/thank-you/"
  noindex={true}
>
  <section class="page-shell">
    <div class="page-inner narrow thank-you">
      <span class="section-label">Intake Received</span>
      <h1>Thanks. We have your answers.</h1>
      <p>
        Based on your answers, an Intro Lesson may be the best next step. Our office can help confirm
        the right teacher, location, and schedule before anything is finalized.
      </p>
      <p>
        This is not an automated teacher match. A real person should review the details first.
      </p>
      <div class="thank-you-actions">
        <a class="btn-a" href="https://cincinnatischoolofmusic.opus1.io/w/book-your-intro-lesson">Book an Intro Lesson</a>
        <a class="btn-c" href="/parent-resources/">Visit Parent Resources</a>
      </div>
    </div>
  </section>

  <style>
    .thank-you{padding-top:104px}
    .thank-you p{margin-bottom:18px}
    .thank-you-actions{display:flex;flex-wrap:wrap;gap:12px;margin-top:34px}
  </style>
</Base>
