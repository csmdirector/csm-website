---
import Base from '../../layouts/Base.astro';
---
<Base
  title="Intro Lesson Next Step | Cincinnati School of Music"
  description="Continue from the Smart Intro Intake to book an Intro Lesson with Cincinnati School of Music."
  canonicalPath="/smart-intro-intake/thank-you/"
  noindex={true}
>
  <section class="page-shell">
    <div class="page-inner narrow thank-you">
      <span class="section-label">Next Step</span>
      <h1 id="thankYouTitle">Continue to your Intro Lesson booking.</h1>
      <p id="thankYouLead">
        Thanks. Your answers give our office context if you need help.
      </p>
      <p id="thankYouBody">
        The next step is the Cincinnati School of Music booking page for your Intro Lesson.
      </p>
      <div class="thank-you-actions">
        <a class="btn-a" id="thankYouBookingLink" href="https://cincinnatischoolofmusic.opus1.io/w/book-your-intro-lesson">Book an Intro Lesson</a>
        <a class="btn-c help-link" id="thankYouCallLink" href="tel:5135609175">Call CSM</a>
        <a class="btn-c help-link" id="thankYouTextLink" href="sms:5135609175">Text CSM</a>
        <a class="btn-c help-link" id="thankYouEmailLink" href="mailto:info@cincinnatischoolofmusic.com">Email CSM</a>
        <a class="btn-c" href="/parent-resources/">Visit Parent Resources</a>
      </div>
    </div>
  </section>

  <style>
    .thank-you{padding-top:104px}
    .thank-you p{margin-bottom:18px}
    .thank-you-actions{display:flex;flex-wrap:wrap;gap:12px;margin-top:34px}
    .help-link{display:none}
    .thank-you.is-help .help-link{display:inline-block}
    .thank-you.is-help #thankYouBookingLink{display:none}
  </style>

  <script>
    (function(){
      var link = document.getElementById('thankYouBookingLink');
      var keys = ['utm_source','utm_medium','utm_campaign','utm_content','utm_term','gclid','gbraid','wbraid'];
      var params = new URLSearchParams(window.location.search);
      var isHelp = params.get('help') === '1';
      try {
        var stored = JSON.parse(window.localStorage.getItem('csmSmartIntroAttribution') || '{}') || {};
        if(link){
          var url = new URL(link.href);
          keys.forEach(function(key){
            if(stored[key]){
              url.searchParams.set(key, stored[key]);
            }
          });
          link.href = url.toString();
        }
      } catch (error) {}
      if(isHelp){
        var shell = document.querySelector('.thank-you');
        var title = document.getElementById('thankYouTitle');
        var lead = document.getElementById('thankYouLead');
        var body = document.getElementById('thankYouBody');
        if(shell) shell.classList.add('is-help');
        if(title) title.textContent = 'We can help you choose a starting point.';
        if(lead) lead.textContent = 'Thanks. Your request was saved for staff follow-up.';
        if(body) body.textContent = 'A member of our team can review your answers and help with the next step.';
      }
    })();
  </script>
</Base>
