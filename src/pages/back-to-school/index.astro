  <script define:vars={{ promoName: campaign.name, promoDeadline: campaign.deadline, offerSavings: campaign.savings }}>
    (function(){
      var form = document.getElementById('backToSchoolClaimForm');
      if(!form) return;

      var ATTRIBUTION_KEYS = ['utm_source','utm_medium','utm_campaign','utm_content','utm_term','fbclid'];
      var STORAGE_KEY = 'csmBackToSchoolAttribution';
      var THANK_YOU_PAYLOAD_KEY = 'csmBackToSchoolClaimPayload';

      function getStoredAttribution(){
        try {
          return JSON.parse(window.localStorage.getItem(STORAGE_KEY) || '{}') || {};
        } catch (error) {
          return {};
        }
      }

      function setStoredAttribution(value){
        try {
          window.localStorage.setItem(STORAGE_KEY, JSON.stringify(value));
        } catch (error) {}
      }

      function hasNewAttribution(params){
        return ATTRIBUTION_KEYS.some(function(key){
          var value = params.get(key);
          return Boolean(value && value.trim());
        });
      }

      function captureAttribution(){
        var params = new URLSearchParams(window.location.search);
        var stored = getStoredAttribution();
        var hasCampaignOnUrl = hasNewAttribution(params);

        if(hasCampaignOnUrl || !stored.landing_path){
          ATTRIBUTION_KEYS.forEach(function(key){
            var value = params.get(key);
            stored[key] = value && value.trim() ? value.trim() : '';
          });
          stored.landing_path = window.location.pathname + window.location.search;
        } else {
          ATTRIBUTION_KEYS.forEach(function(key){
            var value = params.get(key);
            if(value && value.trim()) stored[key] = value.trim();
          });
        }

        setStoredAttribution(stored);
        return stored;
      }

      function fieldValue(name){
        var field = form.elements[name];
        return field ? String(field.value || '').trim() : '';
      }

      function setValue(id, value){
        var field = document.getElementById(id);
        if(field) field.value = value || '';
      }

      function updateAttributionFields(){
        var attribution = captureAttribution();
        setValue('btsUtmSource', attribution.utm_source);
        setValue('btsUtmMedium', attribution.utm_medium);
        setValue('btsUtmCampaign', attribution.utm_campaign);
        setValue('btsUtmContent', attribution.utm_content);
        setValue('btsUtmTerm', attribution.utm_term);
        setValue('btsFbclid', attribution.fbclid);
        setValue('btsLandingPath', attribution.landing_path);
      }

      function buildPayload(){
        var attribution = getStoredAttribution();
        return {
          promo_name: promoName,
          promo_deadline: promoDeadline,
          offer_savings: offerSavings,
          parent_guardian_name: fieldValue('parent_guardian_name'),
          phone: fieldValue('phone'),
          email: fieldValue('email'),
          student_name: fieldValue('student_name'),
          student_age: fieldValue('student_age'),
          interested_lesson: fieldValue('interested_lesson'),
          preferred_location: fieldValue('preferred_location'),
          best_days_times: fieldValue('best_days_times'),
          notes_questions: fieldValue('notes_questions'),
          utm_source: attribution.utm_source || '',
          utm_medium: attribution.utm_medium || '',
          utm_campaign: attribution.utm_campaign || '',
          utm_content: attribution.utm_content || '',
          utm_term: attribution.utm_term || '',
          fbclid: attribution.fbclid || '',
          landing_path: attribution.landing_path || '',
          submitted_at: fieldValue('submitted_at')
        };
      }

      updateAttributionFields();
      form.addEventListener('change', updateAttributionFields);
      form.addEventListener('submit', function(){
        updateAttributionFields();
        setValue('btsSubmittedAt', new Date().toISOString());
        try {
          window.sessionStorage.setItem(THANK_YOU_PAYLOAD_KEY, JSON.stringify(buildPayload()));
        } catch (error) {}
      });
    })();
  </script>
