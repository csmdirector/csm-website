---
import Base from '../../layouts/Base.astro';
---
<Base
  title="July Start Special Received | Cincinnati School of Music"
  description="Thanks for claiming the July Start Special at Cincinnati School of Music."
  canonicalPath="/promos/thank-you/"
  noindex={true}
>
  <section class="page-shell">
    <div class="page-inner narrow promo-thanks">
      <span class="section-label">Request Received</span>
      <h1 id="thankYouTitle">Thanks. Your July Start Special request was sent.</h1>
      <p id="thankYouLead">
        Thanks - we received your July Start Special request. Our team will follow up to help you
        find the right lesson, location, and time.
      </p>
      <p>
        No payment was collected with this form. Offer valid through 7/14/26. If you want to talk
        sooner, call or text the office.
      </p>
      <div class="thank-you-actions">
        <a class="btn-a" href="tel:5135609175">Call CSM</a>
        <a class="btn-c" href="sms:5135609175">Text CSM</a>
        <a class="btn-c" href="mailto:info@cincinnatischoolofmusic.com">Email CSM</a>
      </div>
    </div>
  </section>

  <style>
    .promo-thanks{padding-top:104px}
    .promo-thanks p{margin-bottom:18px}
    .thank-you-actions{display:flex;flex-wrap:wrap;gap:12px;margin-top:34px}
  </style>

  <script>
    (function(){
      var PAYLOAD_KEY = 'csmPromoClaimPayload';
      var LEAD_EVENT_PUSHED_KEY = 'csmPromoLeadEventPushedFor';

      try {
        var payload = JSON.parse(window.sessionStorage.getItem(PAYLOAD_KEY) || '{}') || {};
        var submissionKey = payload.submitted_at || '';
        var alreadyPushedFor = window.sessionStorage.getItem(LEAD_EVENT_PUSHED_KEY) || '';

        if(window.dataLayer && payload.promo_name && submissionKey && alreadyPushedFor !== submissionKey){
          payload.event = 'promo_claim_submit';
          window.dataLayer.push(payload);
          if(typeof window.fbq === 'function'){
            window.fbq('track', 'Lead', {
              content_name: payload.promo_name,
              content_category: 'Promo Claim',
              promotion_deadline: payload.promo_deadline || '',
              utm_source: payload.utm_source || '',
              utm_medium: payload.utm_medium || '',
              utm_campaign: payload.utm_campaign || '',
              utm_content: payload.utm_content || '',
              utm_term: payload.utm_term || '',
              fbclid: payload.fbclid || '',
              landing_path: payload.landing_path || ''
            });
          }
          window.sessionStorage.setItem(LEAD_EVENT_PUSHED_KEY, submissionKey);
        }
      } catch (error) {}
    })();
  </script>
</Base>
